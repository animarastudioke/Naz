NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://kazihq:kazihq@localhost:5432/kazihq?schema=public"

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

WEB_APP_URL=http://localhost:3000

# M-Pesa Daraja (per-business overrides stored in BusinessIntegration; these are platform defaults / sandbox)
MPESA_ENV=sandbox
MPESA_CALLBACK_BASE_URL=https://your-api-domain.example.com

# Stripe
STRIPE_WEBHOOK_SECRET=whsec_change_me

# WhatsApp Cloud API (Meta)
WHATSAPP_VERIFY_TOKEN=change-me-verify-token
WHATSAPP_API_VERSION=v20.0

# AI (Claude via Anthropic API) for quote generation from WhatsApp conversation
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="KaziHQ <no-reply@kazihq.app>"
